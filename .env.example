# Database (Supabase — same instance as biassemble-core)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Auth — shared secret between biassemble-core and biassemble-engine
RAG_API_KEY=your-secret-key-here

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Retrieval tuning — establish baseline via run_evaluation.py before changing
TAXONOMY_VERSION=2026-06-28
SEARCH_TOP_K=20
RETURN_TOP_K=5
SIMILARITY_THRESHOLD=0.45

# Experimentation
QUERY_STRATEGY=repeated_story
RERANK_STRATEGY=max

# Indexing
INDEX_BATCH_SIZE=32

# Service timeouts
REQUEST_TIMEOUT_MS=450

# Logging
LOG_LEVEL=INFO
