# Single source of truth for this HF Space's deployed configuration
# (https://huggingface.co/spaces/Leminds/biassemble-engine "Variables" tab).
#
# WHY THIS FILE EXISTS: HF Space Variables always override the Dockerfile's `ENV`
# lines (standard Docker -e vs ENV precedence) — but until now, Space Variables were
# only ever edited by hand in the web UI, invisible to git, git diff, and code review.
# That's exactly how REQUEST_TIMEOUT_MS silently stayed at 60000 in production while
# the Dockerfile (and everyone reading it) said 120000 — 2026-07-13.
#
# Change a deployed value here, then run:
#   uv run scripts/sync_space_vars.py
# Do NOT edit the Space's "Variables" web UI directly — it will drift out of sync
# with this file the same way it just did.
#
# Secrets (DATABASE_URL, RAG_API_KEY, ...) are NOT here — those stay as HF Space
# Secrets, managed only through the web UI, never committed to git.

LOG_LEVEL=INFO
TAXONOMY_VERSION=2026-07-06.1

# Retrieval / embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
QUERY_STRATEGY=repeated_story
SEARCH_TOP_K=20
RETURN_TOP_K=5
SIMILARITY_THRESHOLD=0.400
RERANK_STRATEGY=max
INDEX_BATCH_SIZE=32
PSQL_SEARCH=false

# Selection strategy (ADR-003: llm_union — Gemma-3-4B)
SELECTION_STRATEGY=llm_union
REQUEST_TIMEOUT_MS=120000
EVALUATE_TIMEOUT_S=1800

# nli_union tuning (unused while SELECTION_STRATEGY=llm_union, kept for quick revert)
W_NLI=0.5
W_VEC=0.5
NLI_GATE=0.95
VEC_GATE=0.35
COMBINED_THRESHOLD=0.50
HYPOTHESES_PATH=hypotheses/v2.yaml
